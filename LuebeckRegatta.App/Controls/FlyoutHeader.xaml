<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:LuebeckRegatta.App.ViewModels"
             x:Class="LuebeckRegatta.App.Controls.FlyoutHeader"
             x:DataType="viewmodel:FlyoutHeaderViewModel">
    <Grid RowDefinitions="Auto,Auto" 
          BackgroundColor="White">
        <Image 
            Source="lrvlogo.png"
            Aspect="AspectFit"
            Opacity="0.6"
            Grid.Row="0" />
        <Border StrokeThickness="1"
                Stroke="{StaticResource Primary}"
                BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray800}}"
                Padding="15,10"
                Grid.Row="1">
            <VerticalStackLayout Spacing="2">
                <Label Text="Ausgewähltes Event:"
                       FontSize="10"
                       TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"/>
                <Label Text="{Binding SelectedEventName}"
                       FontSize="14"
                       FontAttributes="Bold"
                       TextColor="{StaticResource Primary}"
                       LineBreakMode="TailTruncation"/>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentView>
