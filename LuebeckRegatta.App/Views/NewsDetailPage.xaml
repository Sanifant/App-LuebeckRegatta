<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LuebeckRegatta.App.ViewModels"
             x:Class="LuebeckRegatta.App.Views.NewsDetailPage"
             Title="News Details">

    <ScrollView>
        <VerticalStackLayout
            Padding="20"
            Spacing="15">

            <Image
                Source="{Binding NewsItem.ImageUrl}"
                Aspect="AspectFill"
                HeightRequest="200"
                IsVisible="{Binding HasImage}" />

            <Label
                Text="{Binding NewsItem.Title}"
                Style="{StaticResource Headline}"
                FontSize="24"
                FontAttributes="Bold" />

            <HorizontalStackLayout Spacing="10">
                <Label
                    Text="{Binding NewsItem.PublishDate, StringFormat='{0:dd.MM.yyyy HH:mm}'}"
                    FontSize="12"
                    TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
                <Label
                    Text="{Binding NewsItem.Author}"
                    FontSize="12"
                    FontAttributes="Italic"
                    TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
            </HorizontalStackLayout>

            <BoxView
                HeightRequest="1"
                Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray500}}" />

            <Label
                Text="{Binding NewsItem.Description}"
                FontSize="16"
                LineBreakMode="WordWrap"
                TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}" />

            <Button
                Text="Artikel online lesen"
                Command="{Binding OpenLinkCommand}"
                Margin="0,20,0,0" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>