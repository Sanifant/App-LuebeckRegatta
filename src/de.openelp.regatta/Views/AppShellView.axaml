<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="de.openelp.regatta.Views.AppShellView">

  <Grid ColumnDefinitions="220,*">
    <!-- Navigation / Menü -->
    <StackPanel Grid.Column="0" Spacing="8" Margin="12">
      <Button Content="Schiedsrichter" Command="{Binding NavigateToRefereeDashboardCommand}" />
      <Button Content="Einstellungen" Command="{Binding NavigateToSettingsCommand}" />
    </StackPanel>

    <!-- Content -->
    <ContentControl Grid.Column="1"
                    Margin="12"
                    Content="{Binding Current}" />
  </Grid>
</UserControl>