<ContentPage
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:vm="using:de.openelp.regatta.ViewModels"
	xmlns:models="using:de.openelp.regatta.Models"
	mc:Ignorable="d"
	d:DesignWidth="1280" d:DesignHeight="800"
	x:Class="de.openelp.regatta.Pages.RefereeDashboardView"
	x:DataType="vm:RefereeDashboardViewModel">
	<Grid ColumnDefinitions="240, *" RowDefinitions="Auto, *">
		<!-- Top Bar -->
		<Border Grid.ColumnSpan="2" Margin="14,14,14,10">
			<DockPanel LastChildFill="True">
				<TextBlock DockPanel.Dock="Left" Text="LÜBECK REGATTA • SCHIEDSRICHTER-ANSICHT" />
				<StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="10">
					<TextBlock Text="Wettkampfrichter:" VerticalAlignment="Center"/>

					<TextBlock Text="{Binding ClockText}"/>
				</StackPanel>
			</DockPanel>
		</Border>

		<!-- LCARS Sidebar -->
		<StackPanel Grid.Row="1" Grid.Column="0" Margin="14,0,10,14" Spacing="10">
			<Border>
				<StackPanel Spacing="10">
					<TextBlock Text="AKTIVE RENNEN"/>
					<TextBlock Text="Nur Status: Running"/>
				</StackPanel>
			</Border>

			<Border>
				<StackPanel Spacing="10">
					<Button Command="{Binding TakeOverCommand}" Width="150" Content="Rennen begleiten"/>
					<Button Command="{Binding SaveNoteCommand}" Width="150" Content="Notiz speichern"/>
					<ComboBox ItemsSource="{Binding Referees}"
							  SelectedItem="{Binding SelectedReferee}"
							  DisplayMemberBinding="{Binding DisplayName}"
							  PlaceholderText="auswählen..."
							   Width="150" />
					<Button Command="{Binding RefreshCommand}" Width="150" Content="Aktualisieren"/>
				</StackPanel>
			</Border>

			<Border>
				<StackPanel Spacing="6">
					<TextBlock Text="STATUS"/>
					<TextBlock Text="{Binding StatusText}"/>
				</StackPanel>
			</Border>
		</StackPanel>

		<!-- Main Content -->
		<Grid Grid.Row="1" Grid.Column="1" Margin="0,0,14,14" RowDefinitions="Auto, Auto, *" ColumnDefinitions="*">
			<!-- Race List (ersetzt Vaadin Grid) -->
			<Border Margin="0,0,0,10">
				<StackPanel Spacing="10">
					<TextBlock Text="Rennenliste"/>
					<DataGrid ItemsSource="{Binding Heats}"
							  SelectedItem="{Binding SelectedHeat}"
							  AutoGenerateColumns="False"
							  IsReadOnly="True"
							  Height="240">
						<DataGrid.Columns>
							<DataGridTextColumn Header="Rennnr." Binding="{Binding RaceNumber}" Width="120"/>
							<DataGridTextColumn Header="Rennen" Binding="{Binding Title}" Width="*"/>
							<DataGridTextColumn Header="Gestartet" Binding="{Binding ActualStartDate}" Width="170"/>
							<DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120"/>
						</DataGrid.Columns>
					</DataGrid>
				</StackPanel>
			</Border>

			<!-- Selected Heat Header -->
			<Border Margin="0,0,0,10">
				<DockPanel>
					<StackPanel DockPanel.Dock="Left">
						<TextBlock Text="{Binding SelectedHeatTitle}"/>
						<TextBlock Text="{Binding SelectedHeatMeta}"/>
					</StackPanel>
					<StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
						<Button Command="{Binding PrevHeatCommand}" Content="◄"/>
						<Button Command="{Binding NextHeatCommand}" Content="►"/>
					</StackPanel>
				</DockPanel>
			</Border>

			<!-- Boats/Tiles area + note (entspricht ItemDetailsRenderer + commentTa) -->
			<Grid RowDefinitions="*, Auto" ColumnDefinitions="*" >
				<Border Grid.Row="0">
					<ItemsControl ItemsSource="{Binding SelectedHeatEntries}">
						<ItemsControl.ItemsPanel>
							<ItemsPanelTemplate>
								<!-- Kacheln nebeneinander, wie heatDetailHL in RefereeView.java -->
								<WrapPanel Orientation="Horizontal" ItemWidth="390" ItemHeight="210" />
							</ItemsPanelTemplate>
						</ItemsControl.ItemsPanel>

						<ItemsControl.ItemTemplate>
							<DataTemplate >
								<!-- Boat Tile Background="{Binding WarningColor}"-->
								<Border 
										x:DataType="models:HeatEntryModel"
										Margin="8">
									<Grid RowDefinitions="Auto,Auto,*,Auto" ColumnDefinitions="Auto,*" ColumnSpacing="10" RowSpacing="6">

										<Border Grid.RowSpan="4" Grid.Column="0" Width="56" Height="56"
												CornerRadius="28"
												VerticalAlignment="Top">
											<TextBlock Text="{Binding Lane}"
													   x:DataType="models:HeatEntryModel"
													   HorizontalAlignment="Center"
													   VerticalAlignment="Center"
													   FontSize="22"
													   FontWeight="Bold"
													   Foreground="Black"/>
										</Border>

										<TextBlock Grid.Column="1" Grid.Row="0"
												   FontSize="18"
												   FontWeight="SemiBold"
												   x:DataType="models:HeatEntryModel"
												   Text="{Binding ShortTeamName}"/>
										<TextBlock Grid.Column="1" Grid.Row="1"
												   Text="{Binding TeamName}"/>

										<TextBlock Grid.Column="1" Grid.Row="2"
												   TextWrapping="Wrap"
												   x:DataType="models:HeatEntryModel"
												   Text="{Binding Athletes}"/>

										<StackPanel Grid.Column="1" Grid.Row="3" Orientation="Horizontal" Spacing="10">
											<Button Content="Verwarnung"/>
											<TextBlock Text="{Binding Status}" VerticalAlignment="Center"/>
										</StackPanel>

									</Grid>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
				</Border>

				<Border Grid.Row="1" Margin="0,10,0,0">
					<StackPanel Spacing="8">
						<TextBlock Text="Bemerkung"/>
						<TextBox AcceptsReturn="True"
								 Height="90"
								 Text="{Binding NoteText}"/>
					</StackPanel>
				</Border>
			</Grid>
		</Grid>
	</Grid>
</ContentPage>