<ContentPage xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:vm="using:de.openelp.regatta.ViewModels"
			 xmlns:models="using:de.openelp.regatta.Models"
             xmlns:regatta="using:de.openelp.regatta"
			 xmlns:icons="using:de.openelp.regatta.Icons"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 x:DataType="vm:SettingsViewModel"
			 x:Class="de.openelp.regatta.Pages.SettingsPage"
			 Header="Einstellungen">
	<ContentPage.Resources>
		<ResourceDictionary>
