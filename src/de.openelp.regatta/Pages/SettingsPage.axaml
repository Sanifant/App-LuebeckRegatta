    </ResourceDictionary>
	</ContentPage.Resources>
	<Grid>
		<StackPanel Margin="14" Spacing="10">
			<StackPanel Orientation="Horizontal" Spacing="10">
				<Label Width="120" Content="Sprache:" VerticalAlignment="Center"/>
				<ComboBox Width="320" PlaceholderText="Sprache auswählen..." IsEnabled="false">
					<ComboBoxItem Content="Deutsch"/>
					<ComboBoxItem Content="Englisch"/>
				</ComboBox>
			</StackPanel>
			<StackPanel Orientation="Horizontal" Spacing="10">
				<Label Width="120" Content="Design:" VerticalAlignment="Center"/>
				<ComboBox Width="320" PlaceholderText="Design auswählen..." 
						  SelectedItem="{Binding SelectedTheme}" 
						  IsEnabled="false" 
						  ItemsSource="{Binding AvailableThemes, Mode=OneWay}">
				</ComboBox>
			</StackPanel>
			<StackPanel Orientation="Horizontal" Spacing="10">
				<Label Width="120" Content="Webservice URL:" VerticalAlignment="Center"/>
				<TextBox Width="320" Text="{Binding WebApiBaseUrl, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
						 PlaceholderText="Webservice Url" />
				<Button Command="{Binding ParseUrlCommand}">
					<PathIcon Grid.Column="0" Width="16" Height="16"
										HorizontalAlignment="Center"
										VerticalAlignment="Center"
										Data="{StaticResource phone_update_regular}"/>
				</Button>
				<Rectangle Fill="{Binding UrlValid}" Width="20" Height="20" />
			</StackPanel>
			<StackPanel Orientation="Horizontal" Spacing="10">
				<Label Width="120" Content="Event:" VerticalAlignment="Center"/>
				<ComboBox Width="320" PlaceholderText="Regatta auswählen..." 
						  ItemsSource="{Binding AvailableEvents}"
						  SelectedItem="{Binding SelectedEvent, Mode=TwoWay}" 
						  DisplayMemberBinding="{Binding Title}">
				</ComboBox>
			</StackPanel>
			<TextBlock Text="Anmeldeinformationen eingeben" Margin="130, 0, 0, 0"  />
			<StackPanel Orientation="Horizontal" Spacing="10">
				<Label Width="120" Content="Benutzername:" VerticalAlignment="Center"/>
				<TextBox Width="320" Text="{Binding UserName, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" PlaceholderText="Benutzername" />
			</StackPanel>
			<StackPanel Orientation="Horizontal" Spacing="10">
				<Label Width="120" Content="Passwort:" VerticalAlignment="Center"/>
				<TextBox Width="320" Text="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" PasswordChar="●"  PlaceholderText="Passwort" />
			</StackPanel>
			<TextBlock Text="{Binding ErrorMessage}" Foreground="Yellow" />
			<StackPanel Orientation="Horizontal" Spacing="10">
				<Button Content="Verbindung testen..." Width="150" Margin="130, 0, 0, 0" 
						Command="{Binding CheckConnectionCommand}"
						IsEnabled="{Binding CanCheckConnection}" />
				<Button Content="Speichern..." Width="150" Margin="10, 0, 0, 0" 
						Command="{Binding SaveChangesCommand}"
						IsEnabled="{Binding CanSaveChanges}" />
			</StackPanel>
			<StackPanel Orientation="Horizontal" Spacing="10">
				<Label Width="120" Content="Is Debug:" VerticalAlignment="Center"/>
				<CheckBox Width="250" IsChecked="{Binding IsDebugMode, Mode=TwoWay}" />
			</StackPanel>
			<StackPanel Orientation="Horizontal" Spacing="10">
			</StackPanel>

			<!-- Weitere Einstellungen hier hinzufügen -->
		</StackPanel>
	</Grid>
</ContentPage>
